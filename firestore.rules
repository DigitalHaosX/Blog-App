// Firestore security rules
// Apply via: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Articles: read by anyone, write by authenticated users ──
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── Comments / ratings: read by anyone, write by authenticated ──
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // ── Page views: write by anyone (public analytics), read by owner ──
    match /pageViews/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Analytics summary: read by authenticated, write by Cloud Functions only ──
    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions use Admin SDK (bypasses rules)
    }

    // ── Sessions (dedup store): Cloud Functions only ──
    match /sessions/{sessionId} {
      allow read, write: if false; // Admin SDK only
    }
  }
}
