# ── Firebase ──────────────────────────────────────────────────────────────────
# Copy these values from: Firebase Console → Project Settings → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Site owner ────────────────────────────────────────────────────────────────
# Firebase UID of the owner account (can delete any article, access /dashboard)
# Find it: Firebase Console → Authentication → Users → User UID column
VITE_OWNER_UID=
